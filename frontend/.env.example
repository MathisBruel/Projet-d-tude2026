# ============================================
# Configuration d'environnement - AgriSense
# ============================================
# Copier ce fichier en .env et remplir les valeurs

# Google Maps API Key
# Obtenir depuis: https://console.cloud.google.com/
# 1. Créer une clé API (type Android)
# 2. Restreindre à "Applications Android"
# 3. Ajouter: com.agrisense.agrisense + votre SHA-1 fingerprint
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# API Backend URL
# Format: http://host:port (sans trailing slash)
# Dev local: http://10.0.2.2:5000 (émulateur Android)
# Dev local: http://localhost:5000 (device physique sur PC)
API_URL=http://10.0.2.2:5000
