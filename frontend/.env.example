# Backend API URL
# For Android emulator use: http://10.0.2.2:5000
# For iOS simulator use: http://localhost:5000
API_URL=http://10.0.2.2:5000

# Google Maps API Key
# Get yours from: https://developers.google.com/maps/documentation/android-sdk/get-api-key
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Auto-login feature
# Set to 'true' to automatically login on app startup
AUTO_LOGIN=false
AUTO_LOGIN_EMAIL=test@agrisense.com
AUTO_LOGIN_PASSWORD=Test123!
